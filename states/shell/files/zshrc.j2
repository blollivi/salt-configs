export ZSH="{{ home }}/.oh-my-zsh"

ZSH_THEME="{{ theme }}"

# Plugins — order matters: completions before syntax-highlighting
plugins=({{ plugins }})

source $ZSH/oh-my-zsh.sh

# ── Editor ──────────────────────────────────────────────────
export VISUAL="code --wait"
export EDITOR="nano"

# ── uv / Python ─────────────────────────────────────────────
export UV_PYTHON_PREFERENCE=only-managed   # uv manages its own Pythons
. "{{ home }}/.local/bin/env" 2>/dev/null || true  # uv shell env

# ── PATH additions ───────────────────────────────────────────
export PATH="{{ home }}/.local/bin:$PATH"

# ── Aliases ──────────────────────────────────────────────────
alias ls='ls --color=auto'
alias ll='ls -lah'
alias cat='bat --paging=never 2>/dev/null || cat'
alias find='fd 2>/dev/null || find'
alias grep='rg 2>/dev/null || grep --color=auto'
alias vim='code'

# ── fzf ──────────────────────────────────────────────────────
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# ── direnv ───────────────────────────────────────────────────
# >>> direnv hook >>>
eval "$(direnv hook zsh)"
# <<< direnv hook <<<

# ── Powerlevel10k instant prompt (keep near top of .zshrc) ──
[[ -r "{{ home }}/.p10k.zsh" ]] && source "{{ home }}/.p10k.zsh"
